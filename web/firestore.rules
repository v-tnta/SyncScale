rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ログインしているユーザーのみが自分のデータにアクセスできる
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // 同意チェック: 同意済み かつ 撤回していない
    function hasConsented(userId) {
      let consent = get(/databases/$(database)/documents/consents/$(userId));
      return consent != null 
        && !('withdrawnAt' in consent.data);
    }

    // 同意書（撤回時の withdrawnAt 追記と、同意書改訂時の再同意のみ更新可能）
    match /consents/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['agreedAt', 'version'])
        && !('withdrawnAt' in request.resource.data);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['agreedAt', 'version', 'withdrawnAt', 'previousConsents']);
      allow delete: if false;
    }

    // オンボーディング進捗
    match /onboarding/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && hasConsented(userId);
      allow delete: if isOwner(userId); // 撤回時に削除
    }

    // ユーザー設定（通知設定・モバイルプロモ非表示など）
    match /userSettings/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && hasConsented(userId);
      allow delete: if isOwner(userId); // 撤回時に削除
    }

    // タスク
    match /tasks/{taskId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && hasConsented(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId) && hasConsented(request.auth.uid);
    }
    
    // タイムログ
    match /timeLogs/{logId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && hasConsented(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId) && hasConsented(request.auth.uid);
    }
    
    // コンディションログ
    match /conditionLogs/{logId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && hasConsented(request.auth.uid);
      allow create: if isOwner(request.resource.data.userId) && hasConsented(request.auth.uid);
    }

    // 行動ログ（追記専用。read/delete は同意撤回時の全削除のために許可）
    match /activityLogs/{logId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && hasConsented(request.auth.uid);
      allow update: if false;
    }
  }
}
